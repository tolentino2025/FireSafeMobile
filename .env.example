# Server
LICENSE_SECRET_KEY=your-license-secret-key-here
DATABASE_URL=postgresql://localhost:5432/firesafe

# Supabase (fill in after creating project at https://supabase.com)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# JWT
JWT_SECRET=your-jwt-secret-here

# Expo / Mobile (EXPO_PUBLIC_ prefix exposes these to the client bundle)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
