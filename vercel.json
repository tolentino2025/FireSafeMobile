{
  "buildCommand": "EXPO_OFFLINE=1 EXPO_PUBLIC_NO_IAP=1 npx expo export --platform web --output-dir dist --clear",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/_expo/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
